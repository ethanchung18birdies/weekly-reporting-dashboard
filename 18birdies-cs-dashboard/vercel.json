{
  "outputDirectory": "public",
  "functions": {
    "api/ticket-export-plan.js": {
      "maxDuration": 60
    },
    "api/ticket-export-batch.js": {
      "maxDuration": 60
    },
    "api/ticket-export-workbook.js": {
      "maxDuration": 60
    },
    "api/ticket-export-stream.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
